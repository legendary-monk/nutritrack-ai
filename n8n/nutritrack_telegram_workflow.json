      "typeVersion": 4.2,
      "position": [
        2380,
        620
      ],
      "continueOnFail": true,
      "notesInFlow": true,
      "notes": "Generates personalized, short actionable advice.",
      "credentials": {
        "httpHeaderAuth": {
          "id": "gemini-header-auth",
          "name": "Gemini Auth"
        }
      }
    },
    {
      "parameters": {
        "functionCode": "const advice = $json.candidates?.[0]?.content?.parts?.[0]?.text?.trim() || 'Keep protein high in your next meal and stay hydrated.';\nconst hour = Number($now.setZone('Asia/Kolkata').toFormat('H'));\nconst mealType = hour < 11 ? 'Breakfast' : hour < 16 ? 'Lunch' : 'Dinner';\nreturn [{ json: { ...$json, advice, mealType } }];"
      },
      "id": "Prepare Notion Payload",
      "name": "Prepare Notion Payload",
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [
        2600,
        620
      ],
      "notesInFlow": true,
      "notes": "Extracts advice text and computes meal type by India local hour."
    },
    {
      "parameters": {
        "url": "https://api.notion.com/v1/pages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.NOTION_TOKEN}}"
            },
            {
              "name": "Notion-Version",
              "value": "2022-06-28"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"parent\": {\"database_id\": \"{{$json.config.DAILY_NUTRITION_DB}}\"},\n  \"properties\": {\n    \"Name\": {\"title\": [{\"text\": {\"content\": \"{{$json.food_query.substring(0,80)}}\"}}]},\n    \"Date\": {\"date\": {\"start\": \"{{$now.setZone('Asia/Kolkata').toISODate()}}\"}},\n    \"Meal Type\": {\"select\": {\"name\": \"{{$json.mealType}}\"}},\n    \"Calories\": {\"number\": {{$json.cal}}},\n    \"Protein\": {\"number\": {{$json.protein}}},\n    \"Carbs\": {\"number\": {{$json.carbs}}},\n    \"Fat\": {\"number\": {{$json.fat}}},\n    \"Fiber\": {\"number\": {{$json.fiber}}},\n    \"Photo URL\": {\"url\": \"{{$json.telegram_file_id || ''}}\"},\n    \"Advice\": {\"rich_text\": [{\"text\": {\"content\": \"{{$json.advice}}\"}}]},\n    \"Source\": {\"select\": {\"name\": \"Telegram\"}}\n  }\n}",
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 1000
        }
      },
