        "jsonBody": "={\n  \"parent\": {\"database_id\": \"{{$json.config.WATER_WEIGHT_DB}}\"},\n  \"properties\": {\n    \"Name\": {\"title\": [{\"text\": {\"content\": \"Water/Weight {{$now.setZone('Asia/Kolkata').toISODate()}}\"}}]},\n    \"Date\": {\"date\": {\"start\": \"{{$now.setZone('Asia/Kolkata').toISODate()}}\"}},\n    \"Water_L\": {\"number\": {{$json.water_l || 0}}},\n    \"Weight_kg\": {\"number\": {{$json.weight_kg || 0}}}\n  }\n}",
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 1000
        }
