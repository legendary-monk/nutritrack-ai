        "chatId": "={{$json.chat_id || $json.message?.chat?.id}}",
        "text": "=✅ {{$json.mealType}} logged: {{$json.cal}} kcal | P{{$json.protein}} C{{$json.carbs}} F{{$json.fat}}\n{{$json.advice}}",
        "additionalFields": {}
      },
      "id": "Reply Meal Logged",
      "name": "Reply Meal Logged",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        3040,
        620
