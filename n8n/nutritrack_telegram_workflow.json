        1940,
        620
      ],
      "notesInFlow": true,
      "notes": "Combines workout query + daily totals with meal macros for advice generation."
    },
    {
      "parameters": {
        "functionCode": "const workoutResults = $json.results || [];\nconst workout = workoutResults[0]?.properties?.Workout?.rich_text?.[0]?.plain_text || 'Not logged';\n\nconst mealResults = $json.results || [];\nlet tCal=0,tP=0,tC=0,tF=0;\nfor (const r of mealResults) {\n  const p = r.properties || {};\n  tCal += Number(p.Calories?.number || 0);\n  tP += Number(p.Protein?.number || 0);\n  tC += Number(p.Carbs?.number || 0);\n  tF += Number(p.Fat?.number || 0);\n}\n\nconst prompt = `You are my coach. User is in Hubli, India. Goal: ${$env.GOAL}. Today's workout: ${workout}. Current meal: ${$json.food_query} = ${$json.cal}kcal P${$json.protein}g C${$json.carbs}g F${$json.fat}g. Daily totals so far: ${Math.round(tCal)} kcal, P${tP.toFixed(1)}g C${tC.toFixed(1)}g F${tF.toFixed(1)}g. Give 2-sentence actionable advice in English, focus on protein target and timing.`;\n\nreturn [{ json: { ...$json, workout, dailyTotals: { cal: tCal, protein: tP, carbs: tC, fat: tF }, advice_prompt: prompt } }];"
      },
      "id": "Build Advice Prompt",
      "name": "Build Advice Prompt",
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [
        2160,
        620
      ],
      "notesInFlow": true,
      "notes": "Builds deterministic coach prompt including workout + meal + daily totals."
