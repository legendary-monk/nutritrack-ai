        "specifyBody": "json",
        "jsonBody": "={\n  \"system_instruction\": {\n    \"parts\": [{\n      \"text\": \"You are an Indian nutritionist. Describe this meal for tracking with exact portions in natural language for Nutritionix. Use Indian units like katori, medium chapati, handful, bowl, glass. Format strictly like: 2 medium chapatis with ghee, 1.5 katori dal tadka, 100g white rice, 150g curd. Estimate portions from image. No extra text.\"\n    }]\n  },\n  \"contents\": [{\n    \"parts\": [\n      {\n        \"text\": \"Extract meal items with estimated portions for calorie tracking.\"\n      },\n      {\n        \"inline_data\": {\n          \"mime_type\": \"{{$json.image_mime}}\",\n          \"data\": \"{{$json.image_b64}}\"\n        }\n      }\n    ]\n  }]\n}",
        "options": {
