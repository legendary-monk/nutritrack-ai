    {
      "parameters": {
        "functionCode": "const txt = ($json.message?.text || '').trim();\nconst m = txt.match(/(\\d+\\.?\\d*)\\s*(l|kg)/ig) || [];\nlet water = null, weight = null;\nfor (const part of m) {\n  const mm = part.match(/(\\d+\\.?\\d*)\\s*(l|kg)/i);\n  if (!mm) continue;\n  const val = Number(mm[1]);\n  const unit = mm[2].toLowerCase();\n  if (unit === 'l') water = val;\n  if (unit === 'kg') weight = val;\n}\nreturn [{ json: { ...$json, chat_id: $json.message?.chat?.id, water_l: water, weight_kg: weight } }];"
      },
      "id": "Parse WaterWeight",
      "name": "Parse WaterWeight",
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [
        -1120,
        40
      ],
      "notesInFlow": true,
      "notes": "Parses water/weight values with regex /(\\d+\\.?\\d*)\\s*(l|kg)/i."
    },
