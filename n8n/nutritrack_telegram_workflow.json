    {
      "parameters": {
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={{$env.GEMINI_KEY}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"system_instruction\": {\n    \"parts\": [{\"text\": \"You are a concise nutrition and training coach. Return exactly 2 sentences.\"}]\n  },\n  \"contents\": [{\n    \"parts\": [{\"text\": \"{{$json.advice_prompt}}\"}]\n  }]\n}",
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 1200
        }
      },
      "id": "Gemini Advice",
      "name": "Gemini Advice",
