    {
      "parameters": {
        "functionCode": "if ($json.error) return [{ json: $json }];\nconst foods = $json.foods || [];\nconst totals = foods.reduce((acc, f) => {\n  acc.cal += Number(f.nf_calories || 0);\n  acc.protein += Number(f.nf_protein || 0);\n  acc.carbs += Number(f.nf_total_carbohydrate || 0);\n  acc.fat += Number(f.nf_total_fat || 0);\n  acc.fiber += Number(f.nf_dietary_fiber || 0);\n  return acc;\n}, { cal: 0, protein: 0, carbs: 0, fat: 0, fiber: 0 });\n\nreturn [{\n  json: {\n    ...$json,\n    cal: Math.round(totals.cal),\n    protein: Number(totals.protein.toFixed(1)),\n    carbs: Number(totals.carbs.toFixed(1)),\n    fat: Number(totals.fat.toFixed(1)),\n    fiber: Number(totals.fiber.toFixed(1))\n  }\n}];"
      },
      "id": "Sum Nutrition",
      "name": "Sum Nutrition",
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [
        1500,
        620
      ],
      "notesInFlow": true,
      "notes": "Sums Nutritionix foods[] into meal-level macro totals."
    },
